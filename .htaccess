# ── Force HTTPS (if not already handled by server)
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ── Force non-www
RewriteCond %{HTTP_HOST} ^www\.digisyn\.co [NC]
RewriteRule ^ https://digisyn.co%{REQUEST_URI} [R=301,L]

# ── 301 redirects for retired URLs still indexed in Google
RewriteRule ^privacy-policy/?$ /privacy/ [R=301,L]
RewriteRule ^faq/?$ /contact/ [R=301,L]
RewriteRule ^done-for-you-marketing /blog/ [R=301,L]
RewriteRule ^home/?$ / [R=301,L]
RewriteRule ^services/content-creation-marketing/?$ /services/website-content-management/ [R=301,L]
RewriteRule ^services/web-design-development/?$ /services/web-design-and-development/ [R=301,L]
RewriteRule ^the-always-on-brand-how-to-stay-visible-online-without-doing-it-yourself/?$ /blog/ [R=301,L]
RewriteRule ^why-work-with-us/?$ /about/ [R=301,L]
RewriteRule ^templates(\.html)?/?$ /pricing/ [R=301,L]

# ── Strip legacy .html extension left over from the old flat-file URL
#    structure (site now uses clean directory URLs, e.g. /about/). Catches
#    every old /page.html, /blog/post.html, /locations/city.html link still
#    indexed or bookmarked, without needing a rule per page.
RewriteCond %{REQUEST_URI} !^/404\.html$
RewriteRule ^(.*)\.html$ /$1/ [R=301,L]

# ── Add trailing slash to directories (prevents 301 redirect chain)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-l
RewriteCond %{REQUEST_URI} !/$
RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]{1,6}$
RewriteRule ^(.*)$ /$1/ [R=301,L]

# ── Serve index.html for clean URLs
DirectoryIndex index.html
Options -Indexes

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.+?)/?$ /$1/index.html [L]

# ── Custom 404
ErrorDocument 404 /404.html
